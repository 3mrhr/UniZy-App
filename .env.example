# UniZy launch environment example
# Use real values in `.env.local` for local development or your deployment platform for hosted environments.
# Apple OAuth is intentionally disabled for V1, so no APPLE_* variables are required.

# Core runtime
DATABASE_URL=postgresql://replace-with-db-user:replace-with-db-password@replace-with-db-host:5432/unizy?sslmode=require
SESSION_SECRET=replace-with-a-32-character-session-secret
NEXT_PUBLIC_APP_URL=https://replace-with-your-vercel-domain.vercel.app
CRON_SECRET=replace-with-cron-secret
RUN_WORKER=false

# Authentication and email
# Google callback: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
RESEND_API_KEY=replace-with-resend-api-key

# Uploads
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret

# Manual wallet payments shown in the student UI
NEXT_PUBLIC_UNIZY_INSTAPAY_PHONE=replace-with-instapay-phone
NEXT_PUBLIC_UNIZY_VODAFONE_PHONE=replace-with-vodafone-cash-phone

# Internal payment webhook validation
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-secret

# Monitoring
# DSN-only Sentry setup is supported. No SENTRY_AUTH_TOKEN is required for the current repo setup.
NEXT_PUBLIC_SENTRY_DSN=replace-with-public-sentry-dsn
SENTRY_DSN=replace-with-server-sentry-dsn

# Optional realtime and push integrations
REALTIME_PROVIDER=none
PUSH_PROVIDER=none
PUSHER_APP_ID=replace-with-pusher-app-id
PUSHER_KEY=replace-with-pusher-key
PUSHER_SECRET=replace-with-pusher-secret
PUSHER_CLUSTER=eu
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
FIREBASE_CLIENT_EMAIL=replace-with-firebase-client-email
FIREBASE_PRIVATE_KEY=replace-with-firebase-private-key

# Optional storage and cache integrations
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=replace-with-s3-bucket
CACHE_PROVIDER=none
REDIS_URL=redis://localhost:6379
