// This is your Prisma schema file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  role      String   @default("STUDENT") // STUDENT, PROVIDER, ADMIN, DRIVER, MERCHANT, SUPPORT, AMBASSADOR
  name      String
  email     String   @unique
  password  String // In a real app this would be hashed
  phone     String?
  
  // Phase 16: Expanded Profile
  university   String?  @default("Assiut University")
  faculty      String?
  academicYear String?
  gender       String?
  referralCode String?
  isVerified   Boolean  @default(false)
  profileImage String?

  points    Int      @default(0) // UniZy rewards
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings       HousingListing[]
  verifications  VerificationDocument[]
  orders         Order[]
  reviews        Review[]
  supportTickets SupportTicket[]
  deals          Deal[]
  savedDeals     SavedDeal[]
  meals          Meal[]
}

model HousingListing {
  id          String @id @default(uuid())
  title       String
  description String
  price       Float
  type        String // Shared, Studio, Apartment
  status      String @default("PENDING") // PENDING, ACTIVE, REJECTED, RENTED
  location    String
  images      String // JSON stringified array of URLs
  amenities   String // JSON stringified array of strings
  contact     String

  providerId String
  provider   User   @relation(fields: [providerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationDocument {
  id      String @id @default(uuid())
  type    String // STUDENT_ID, DRIVERS_LICENSE, DEED
  status  String @default("PENDING") // PENDING, VERIFIED, REJECTED
  fileUrl String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id      String @id @default(uuid())
  service String // TRANSPORT, DELIVERY
  status  String @default("PENDING") // PENDING, ACCEPTED, IN_TRANSIT, COMPLETED
  total   Float
  details String // JSON stringified specific details (pickup/dropoff or food items)

  userId   String
  user     User    @relation(fields: [userId], references: [id])
  driverId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Optional relations - What is being reviewed?
  targetUserId     String?  // Reviewing a driver or landlord
  housingListingId String?  // Reviewing a specific house
  orderId          String?  // Reviewing a specific transport/delivery order

  createdAt DateTime @default(now())
}

model SupportTicket {
  id       String @id @default(uuid())
  subject  String
  category String
  status   String @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  priority String @default("LOW") // LOW, MEDIUM, HIGH

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deal {
  id          String @id @default(uuid())
  title       String
  description String
  discount    String
  
  category    String @default("other")
  image       String?
  originalPrice Float?
  discountPrice Float?
  currency    String @default("EGP")
  
  rating      Float @default(5.0)
  reviews     Int @default(0)
  expiresIn   String? 
  promoCode   String?
  
  status      String @default("ACTIVE") // ACTIVE, EXPIRED

  merchantId String
  merchant   User   @relation(fields: [merchantId], references: [id])

  savedBy   SavedDeal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedDeal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id])
  
  createdAt DateTime @default(now())

  @@unique([userId, dealId])
}

model Meal {
  id          String   @id @default(uuid())
  name        String
  arName      String?
  description String?
  price       Float
  currency    String   @default("EGP")
  image       String?
  rating      Float    @default(5.0)
  calories    String?
  prepTime    String?
  tags        String   @default("daily") // JSON stringified array or comma separated
  isPopular   Boolean  @default(false)
  status      String   @default("ACTIVE") // ACTIVE, UNAVAILABLE

  merchantId  String
  merchant    User     @relation(fields: [merchantId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
