// This is your Prisma schema file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  role      String   @default("STUDENT") // STUDENT, PROVIDER, ADMIN, DRIVER, MERCHANT, SUPPORT, AMBASSADOR
  name      String
  email     String   @unique
  password  String // bcrypt hashed
  phone     String?
  scopes    String? // JSON array for module-admin scopes (e.g. ["HOUSING", "TRANSPORT"])
  
  // Phase 16: Expanded Profile
  university   String?  @default("Assiut University")
  faculty      String?
  academicYear String?
  gender       String?
  referralCode String?  @unique
  isVerified   Boolean  @default(false)
  verificationStatus String @default("UNVERIFIED") // UNVERIFIED, PENDING, VERIFIED, REJECTED
  profileImage String?
  notificationPrefs String? @default("{\"email\": true, \"push\": true, \"sms\": false}")

  points    Int      @default(0) // UniZy rewards
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings       HousingListing[]
  verifications  VerificationDocument[]
  orders         Order[]
  reviews        Review[]
  supportTickets SupportTicket[]
  assignedTickets SupportTicket[] @relation("AssignedAgent")
  ticketMessages  TicketMessage[]
  deals          Deal[]
  savedDeals     SavedDeal[]
  meals          Meal[]
  hubPosts       HubPost[]
  notifications  Notification[]
  referralsMade  Referral[]  @relation("referrer")
  referralsUsed  Referral[]  @relation("referred")
  serviceBookings   ServiceBooking[]
  cleaningBookings  CleaningBooking[]
  auditLogs         AuditLog[]  @relation("AdminAuditLogs")
  transactions      Transaction[]
  
  // Phase 38-40 back-relations
  refundRequests    Refund[]    @relation("RefundRequests")
  refundApprovals   Refund[]    @relation("RefundApprovals")
  providerSettlements Settlement[] @relation("ProviderSettlements")
  payoutsProcessed  Payout[]    @relation("PayoutProcessor")
  driverDispatches  Dispatch[]  @relation("DriverDispatches")
  
  // Phase 44 back-relations
  savedHousing    SavedHousing[]   @relation("SavedHousing")
  housingRequests HousingRequest[] @relation("HousingRequests")
  
  // Phase 46: Trust & Safety
  reportsSubmitted Report[] @relation("Reporter")
  reportsAgainst   Report[] @relation("TargetUser")
}

model HousingListing {
  id          String @id @default(uuid())
  title       String
  description String
  price       Float
  type        String // Shared, Studio, Apartment
  status      String @default("PENDING") // PENDING, ACTIVE, REJECTED, RENTED
  location    String
  savedBy      SavedHousing[]
  requests     HousingRequest[]
  
  images      String // JSON string array
  amenities   String // JSON string array of strings
  contact     String

  providerId String
  provider   User   @relation(fields: [providerId], references: [id])

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationDocument {
  id      String @id @default(uuid())
  type    String // STUDENT_ID, DRIVERS_LICENSE, VEHICLE_REGISTRATION, BUSINESS_LICENSE, FOOD_PERMIT, DEED
  status  String @default("PENDING") // PENDING, VERIFIED, REJECTED
  fileUrl String
  rejectionReason String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id      String @id @default(uuid())
  service String // TRANSPORT, DELIVERY
  status  String @default("PENDING") // PENDING, ACCEPTED, IN_TRANSIT, COMPLETED
  total   Float
  details String // JSON stringified specific details (pickup/dropoff or food items)

  userId   String
  user     User    @relation(fields: [userId], references: [id])
  driverId String?

  promoCodeId String?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id])

  dispatches Dispatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Optional relations - What is being reviewed?
  targetUserId     String?  // Reviewing a driver or landlord
  housingListingId String?  // Reviewing a specific house
  orderId          String?  // Reviewing a specific transport/delivery order

  createdAt DateTime @default(now())
}

model SupportTicket {
  id              String   @id @default(uuid())
  subject         String
  description     String   @default("")
  category        String   // HOUSING, TRANSPORT, DELIVERY, DEALS, MEALS, OTHER
  priority        String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status          String   @default("OPEN")   // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  assignedAgentId String?
  assignedAgent   User?    @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  
  messages        TicketMessage[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TicketMessage {
  id        String   @id @default(uuid())
  content   String
  isAdmin   Boolean  @default(false)
  
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  
  createdAt DateTime @default(now())
}

model Deal {
  id          String @id @default(uuid())
  title       String
  description String
  discount    String
  
  category    String @default("other")
  image       String?
  originalPrice Float?
  discountPrice Float?
  currency    String @default("EGP")
  
  rating      Float @default(5.0)
  reviews     Int @default(0)
  expiresIn   String? 
  promoCode   String?
  
  status      String @default("ACTIVE") // ACTIVE, EXPIRED

  merchantId String
  merchant   User   @relation(fields: [merchantId], references: [id])

  savedBy      SavedDeal[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedDeal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id])
  
  createdAt DateTime @default(now())

  @@unique([userId, dealId])
}

model Meal {
  id          String   @id @default(uuid())
  name        String
  arName      String?
  description String?
  price       Float
  currency    String   @default("EGP")
  image       String?
  rating      Float    @default(5.0)
  calories    String?
  prepTime    String?
  tags        String   @default("daily") // JSON stringified array or comma separated
  isPopular   Boolean  @default(false)
  status      String   @default("ACTIVE") // ACTIVE, UNAVAILABLE

  merchantId  String
  merchant    User     @relation(fields: [merchantId], references: [id])
  
  transactions Transaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== Phase 22: Hub Posts ==========

model HubPost {
  id        String   @id @default(uuid())
  content   String
  category  String   @default("general") // general, study_help, lost_found, housing, marketplace
  imageUrl  String?
  likes     Int      @default(0)
  comments  Int      @default(0)
  isFlagged Boolean  @default(false)
  flagReason String?
  status    String   @default("ACTIVE") // ACTIVE, FLAGGED, REMOVED

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== Phase 23: Referrals ==========

model Referral {
  id          String   @id @default(uuid())
  code        String   // The referral code used
  status      String   @default("COMPLETED") // COMPLETED, PENDING
  pointsAwarded Int    @default(50)

  referrerId  String
  referrer    User     @relation("referrer", fields: [referrerId], references: [id])

  referredId  String
  referred    User     @relation("referred", fields: [referredId], references: [id])

  createdAt   DateTime @default(now())
}

// ========== Phase 23: Campaigns ==========

model Campaign {
  id          String   @id @default(uuid())
  title       String
  message     String
  targetRole  String?  // null = all, or STUDENT, DRIVER, etc.
  targetUni   String?  // null = all universities
  status      String   @default("DRAFT") // DRAFT, SENT, SCHEDULED
  sentAt      DateTime?
  scheduledAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== Notifications ==========

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("GENERAL") // GENERAL, CAMPAIGN, REFERRAL, ORDER, SYSTEM
  isRead    Boolean  @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ========== Password Reset ==========

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())
}

// ========== Phase 48: Promotions & Coupons ==========

model PromoCode {
  id              String   @id @default(uuid())
  code            String   @unique
  discountType    String   // PERCENTAGE, FIXED
  discountAmount  Float
  maxUses         Int      @default(0) // 0 = unlimited
  currentUses     Int      @default(0)
  expiresAt       DateTime?
  applicableType  String   // ALL, DELIVERY, TRANSPORT, HOUSING, SERVICES
  isActive        Boolean  @default(true)
  
  orders          Order[]
  transactions    Transaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ========== OTP Verification ==========

model OTP {
  id        String   @id @default(uuid())
  identifier String  // email or phone
  code      String   // 6 digits
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())
}

// ========== Home Services ==========

model ServiceProvider {
  id          String   @id @default(uuid())
  name        String
  phone       String
  category    String   // PLUMBER, ELECTRICIAN, CARPENTER, AC_TECH, PAINTER, GENERAL
  description String?
  priceRange  String?  // e.g. "150-300 EGP"
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  available   Boolean  @default(true)
  verified    Boolean  @default(false)
  imageUrl    String?
  location    String?  @default("Assiut")

  bookings    ServiceBooking[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceBooking {
  id          String   @id @default(uuid())
  status      String   @default("PENDING") // PENDING, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED
  date        String   // e.g. "2026-03-15"
  timeSlot    String   // e.g. "10:00 AM - 12:00 PM"
  notes       String?
  rating      Int?     // 1-5 star rating after completion
  review      String?

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  providerId  String
  provider    ServiceProvider @relation(fields: [providerId], references: [id])

  transactions Transaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== Housing Cleaning Services ==========

model CleaningPackage {
  id          String   @id @default(uuid())
  name        String   // e.g. "Deep Clean", "Weekly Standard", "Move-in/Move-out"
  description String?
  price       Float
  duration    String?  // e.g. "2-3 hours"
  frequency   String   @default("ONE_TIME") // ONE_TIME, WEEKLY, BI_WEEKLY, MONTHLY
  includes    String?  // JSON list of what's included
  active      Boolean  @default(true)

  bookings    CleaningBooking[]

  createdAt   DateTime @default(now())
}

model CleaningBooking {
  id          String   @id @default(uuid())
  status      String   @default("PENDING") // PENDING, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED
  date        String
  timeSlot    String
  address     String
  notes       String?
  rating      Int?
  review      String?

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  packageId   String
  package     CleaningPackage @relation(fields: [packageId], references: [id])

  transactions Transaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== Phase 32: Audit Logs ==========

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g., "UPDATE_ROLE", "APPROVE_LISTING", "PRICE_CHANGE"
  module    String   // e.g., "USERS", "HOUSING", "TRANSPORT", "FINANCE"
  targetId  String?  // ID of the affected user, listing, or order
  details   String?  // JSON stringified additional info

  adminId   String
  admin     User     @relation("AdminAuditLogs", fields: [adminId], references: [id])

  createdAt DateTime @default(now())
}

// ========== Phase 33-34: Core Transaction Engine ==========

model Transaction {
  id              String      @id @default(uuid())
  txnCode         String      @unique // e.g. TXN-2026-XXXXXX
  type            String      // e.g., "HOUSING", "TRANSPORT", "DELIVERY", "DEALS", "MEALS", "SERVICE"
  status          String      @default("PENDING") // PENDING, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED
  
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  
  // Optional relations to specific modules
  housingId       String?
  housing         HousingListing? @relation(fields: [housingId], references: [id], onDelete: SetNull)
  serviceBookingId String?
  serviceBooking  ServiceBooking? @relation(fields: [serviceBookingId], references: [id], onDelete: SetNull)
  cleaningBookingId String?
  cleaningBooking CleaningBooking? @relation(fields: [cleaningBookingId], references: [id], onDelete: SetNull)
  dealId          String?
  deal            Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  mealId          String?
  meal            Meal?           @relation(fields: [mealId], references: [id], onDelete: SetNull)

  promoCodeId     String?
  promoCode       PromoCode?      @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  amount          Float       @default(0.0)
  currency        String      @default("EGP")
  
  notes           String?
  
  history         TransactionHistory[]
  payments        Payment[]
  refunds         Refund[]
  dispatches      Dispatch[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model TransactionHistory {
  id              String      @id @default(uuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  oldStatus       String?
  newStatus       String
  actorId         String      // User ID of who made the change
  reason          String?     // Optional explanation for the change (e.g. cancellation reason)

  createdAt       DateTime    @default(now())
}


model Zone {
  id          String        @id @default(uuid())
  name        String        @unique
  city        String?
  isActive    Boolean       @default(true)
  
  pricingRules PricingRule[]
  commissionRules CommissionRule[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PricingRule {
  id            String      @id @default(uuid())
  module        String      // HOUSING, TRANSPORT, DELIVERY, DEALS, MEALS, SERVICES, CLEANING
  serviceType   String      // BASE_FARE, LISTING_FEE, COMMISSION, DELIV_FEE, etc.
  basePrice     Float       @default(0)
  feeComponents String?     // JSON string for complex fee structures
  
  zoneId        String?     // Optional: If null, applies globally
  zone          Zone?       @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  
  effectiveDate DateTime    @default(now())
  isActive      Boolean     @default(true)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model CommissionRule {
  id                    String      @id @default(uuid())
  module                String      // HOUSING, TRANSPORT, DELIVERY, DEALS, MEALS, SERVICES, CLEANING
  providerType          String      // DRIVER, MERCHANT, LANDLORD, CLEANER, PROVIDER
  unizySharePercent     Float       @default(0) // e.g. 15.5 for 15.5%
  providerSharePercent  Float       @default(100) // The remaining cut
  promoSubsidyImpact    String?     // Optional JSON: e.g. {"whoPaysDiscount": "UNIZY", "amount": 100}

  zoneId                String?     
  zone                  Zone?       @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  effectiveDate         DateTime    @default(now())
  isActive              Boolean     @default(true)

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model Payment {
  id              String      @id @default(uuid())
  
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  amount          Float       @default(0)
  currency        String      @default("EGP")
  method          String      // COD, CASH, CARD, WALLET
  status          String      @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  
  paidAt          DateTime?
  failedReason    String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ========== Phase 38: Refunds & Adjustments ==========

model Refund {
  id              String      @id @default(uuid())
  
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  amount          Float
  currency        String      @default("EGP")
  type            String      @default("FULL") // FULL, PARTIAL
  reason          String
  status          String      @default("REQUESTED") // REQUESTED, APPROVED, REJECTED, PROCESSED
  
  requestedById   String
  requestedBy     User        @relation("RefundRequests", fields: [requestedById], references: [id])
  
  approvedById    String?
  approvedBy      User?       @relation("RefundApprovals", fields: [approvedById], references: [id])
  
  processedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ========== Phase 39: Settlement & Payout Engine ==========

model Settlement {
  id              String      @id @default(uuid())
  
  providerId      String
  provider        User        @relation("ProviderSettlements", fields: [providerId], references: [id])
  
  periodStart     DateTime
  periodEnd       DateTime
  
  grossAmount     Float       @default(0)
  commissionAmount Float      @default(0)
  netAmount       Float       @default(0)
  currency        String      @default("EGP")
  
  status          String      @default("PENDING") // PENDING, PROCESSING, PAID, FAILED
  
  payouts         Payout[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Payout {
  id              String      @id @default(uuid())
  
  settlementId    String
  settlement      Settlement  @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  
  amount          Float
  currency        String      @default("EGP")
  method          String      // BANK_TRANSFER, MOBILE_WALLET, CASH
  reference       String?     // External transaction reference
  status          String      @default("PENDING") // PENDING, PROCESSING, PAID, FAILED
  
  processedById   String?
  processedBy     User?       @relation("PayoutProcessor", fields: [processedById], references: [id])
  
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ========== Phase 40: Dispatch System ==========

model Dispatch {
  id              String      @id @default(uuid())
  
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  transactionId   String?
  transaction     Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  driverId        String?
  driver          User?       @relation("DriverDispatches", fields: [driverId], references: [id])
  
  status          String      @default("PENDING") // PENDING, ASSIGNED, ACCEPTED, DECLINED, FAILED, COMPLETED, CANCELLED
  assignedById    String?     // ID of the admin who manually assigned, if applicable
  delayReason     String?
  isOverride      Boolean     @default(false)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ========== Phase 42: SLA Rules & Monitoring ==========

model SLARule {
  id               String      @id @default(uuid())
  module           String      // "TRANSPORT", "DELIVERY", "HOUSING", "SUPPORT"
  metric           String      // "ASSIGNMENT_TIME", "RESPONSE_TIME", "RESOLUTION_TIME"
  thresholdMinutes Int
  breachAction     String      // "ALERT_ADMIN", "AUTO_CANCEL", "ESCALATE"
  active           Boolean     @default(true)
  breaches         SLABreach[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model SLABreach {
  id         String    @id @default(uuid())
  ruleId     String
  rule       SLARule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  targetId   String    // ID of the breached transaction/order
  status     String    @default("OPEN") // "OPEN", "RESOLVED"
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ========== Phase 44: End-to-End Tracking Models ==========

model SavedHousing {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation("SavedHousing", fields: [userId], references: [id])
  housingListingId String
  listing          HousingListing  @relation(fields: [housingListingId], references: [id])
  
  createdAt        DateTime        @default(now())

  @@unique([userId, housingListingId])
}

model HousingRequest {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation("HousingRequests", fields: [userId], references: [id])
  housingListingId String
  listing          HousingListing  @relation(fields: [housingListingId], references: [id])
  
  type             String          // VIEWING, BOOKING, INQUIRY
  status           String          @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  message          String?         // Optional message from the requester
  date             DateTime?       // Requested date for viewing

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

// ========== Phase 46: Trust, Reporting, and Abuse Handling ==========

model Report {
  id          String   @id @default(uuid())
  type        String   // HOUSING, MERCHANT, DRIVER, HUB_POST, USER
  targetId    String   // ID of the listing, merchant, post, etc.
  
  reason      String   // SCAM, HARASSMENT, INACCURATE, OFFENSIVE, OTHER
  details     String?  // Additional context from the reporter
  
  status      String   @default("PENDING") // PENDING, INVESTIGATING, RESOLVED, DISMISSED
  actionTaken String?  // WARNING, CONTENT_REMOVED, USER_BANNED, NONE
  
  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
  
  // Optional: If the report is specifically against a user
  targetUserId String?
  targetUser   User?    @relation("TargetUser", fields: [targetUserId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
