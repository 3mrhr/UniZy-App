generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                 @id @default(uuid())
  role                UserRole               @default(STUDENT)
  name                String
  email               String                 @unique
  password            String
  phone               String?                @unique
  scopes              Json?
  university          String?                @default("Assiut University")
  faculty             String?
  academicYear        String?
  gender              String?
  referralCode        String?                @unique
  isVerified          Boolean                @default(false)
  status              UserStatus             @default(ACTIVE)
  verificationStatus  String                 @default("UNVERIFIED")
  profileImage        String?
  notificationPrefs   String?                @default("{\"email\": true, \"push\": true, \"sms\": false}")
  points              Int                    @default(0)
  // Merchant-specific store fields
  storeName           String?
  storeAddress        String?
  storeDescription    String?
  storeOpen           Boolean                @default(false)
  // Security Hardening
  mfaEnabled          Boolean                @default(false)
  mfaSecret           String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  auditLogs           AuditLog[]             @relation("AdminAuditLogs")
  cleaningBookings    CleaningBooking[]
  deals               Deal[]
  driverDispatches    Dispatch[]             @relation("DriverDispatches")
  listings            HousingListing[]
  housingRequests     HousingRequest[]       @relation("HousingRequests")
  hubPosts            HubPost[]
  meals               Meal[]
  notifications       Notification[]
  orders              Order[]
  driverOrders        Order[]                @relation("DriverOrders")
  payoutsProcessed    Payout[]               @relation("PayoutProcessor")
  referralsUsed       Referral[]             @relation("referred")
  referralsMade       Referral[]             @relation("referrer")
  refundApprovals     Refund[]               @relation("RefundApprovals")
  refundsProcessed    Refund[]               @relation("RefundProcessor")
  refundRequests      Refund[]               @relation("RefundRequests")
  reportsSubmitted    Report[]               @relation("Reporter")
  reportsAgainst      Report[]               @relation("TargetUser")
  reviews             Review[]
  rewardAccount       RewardAccount?
  rewardTransactions  RewardTransaction[]
  savedDeals          SavedDeal[]
  savedHousing        SavedHousing[]         @relation("SavedHousing")
  serviceBookings     ServiceBooking[]
  providerSettlements Settlement[]           @relation("ProviderSettlements")
  assignedTickets     SupportTicket[]        @relation("AssignedAgent")
  supportTickets      SupportTicket[]
  ticketMessages      TicketMessage[]
  transactions        Transaction[]
  verifications       VerificationDocument[]
  tripsRequested      TransportTrip[]        @relation("TripUser")
  tripsDriven         TransportTrip[]        @relation("TripDriver")
  sessions            Session[]
  accounts            Account[]
  roommateRequests    RoommateRequest[]
  hubComments         HubComment[]
  hubLikes            HubLike[]
  customDeliveries    CustomDeliveryRequest[] @relation("UserCustomDeliveries")
  courierDeliveries   CustomDeliveryRequest[] @relation("CourierCustomDeliveries")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model HousingListing {
  id           String           @id @default(uuid())
  title        String
  description  String
  price        Float
  type         String
  status       HousingStatus    @default(PENDING)
  location     String
  images       String
  amenities    String
  contact      String
  providerId   String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  provider     User             @relation(fields: [providerId], references: [id])
  requests     HousingRequest[]
  savedBy      SavedHousing[]
  transactions Transaction[]

  @@index([status])
}

model VerificationDocument {
  id              String   @id @default(uuid())
  type            String
  status          String   @default("PENDING")
  fileUrl         String
  rejectionReason String?
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model Order {
  id                String              @id @default(uuid())
  service           String
  status            OrderStatus         @default(PENDING)
  total             Float
  details           String
  userId            String
  driverId          String?
  promoCodeId       String?
  pickupProofImage  String?
  dropoffProofImage String?
  deliveryOTP       String?
  failedOtpAttempts Int                @default(0)
  pickupLat         Float?
  pickupLng         Float?
  dropoffLat        Float?
  dropoffLng        Float?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  dispatches        Dispatch[]
  promoCode         PromoCode?          @relation(fields: [promoCodeId], references: [id])
  user              User                @relation(fields: [userId], references: [id])
  driver            User?               @relation("DriverOrders", fields: [driverId], references: [id])
  orderItems        OrderItem[]
  refunds           Refund[]
  rewardTxns        RewardTransaction[]
  transactions      Transaction[]

  @@index([userId, status])
}

model Review {
  id               String   @id @default(uuid())
  rating           Int
  comment          String?
  userId           String
  targetUserId     String?
  housingListingId String?
  orderId          String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model OrderItem {
  id                String                      @id @default(uuid())
  orderId           String
  mealId            String?
  nameSnapshot      String
  basePriceSnapshot Float
  qty               Int
  notes             String?
  createdAt         DateTime                    @default(now())
  order             Order                       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addonSelections   OrderItemAddonSelection[]
  variantSelections OrderItemVariantSelection[]
}

model OrderItemVariantSelection {
  id                 String    @id @default(uuid())
  orderItemId        String
  groupNameSnapshot  String
  optionNameSnapshot String
  priceDeltaSnapshot Float
  createdAt          DateTime  @default(now())
  orderItem          OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model OrderItemAddonSelection {
  id                 String    @id @default(uuid())
  orderItemId        String
  groupNameSnapshot  String
  optionNameSnapshot String
  priceDeltaSnapshot Float     @default(0)
  createdAt          DateTime  @default(now())
  orderItem          OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id              String          @id @default(uuid())
  subject         String
  description     String          @default("")
  category        String
  priority        String          @default("MEDIUM")
  status          TicketStatus    @default(OPEN)
  userId          String
  assignedAgentId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assignedAgent   User?           @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  messages        TicketMessage[]

  @@index([userId, status])
}

model TicketMessage {
  id        String        @id @default(uuid())
  content   String
  isAdmin   Boolean       @default(false)
  ticketId  String
  senderId  String
  createdAt DateTime      @default(now())
  sender    User          @relation(fields: [senderId], references: [id])
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Deal {
  id            String        @id @default(uuid())
  title         String
  description   String
  discount      String
  category      String        @default("other")
  image         String?
  originalPrice Float?
  discountPrice Float?
  currency      String        @default("EGP")
  rating        Float         @default(5.0)
  reviews       Int           @default(0)
  expiresIn     String?
  promoCode     String?
  status        String        @default("ACTIVE")
  merchantId    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  merchant      User          @relation(fields: [merchantId], references: [id])
  savedBy       SavedDeal[]
  transactions  Transaction[]
}

model SavedDeal {
  id        String   @id @default(uuid())
  userId    String
  dealId    String
  createdAt DateTime @default(now())
  deal      Deal     @relation(fields: [dealId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, dealId])
}

model Meal {
  id                String             @id @default(uuid())
  name              String
  arName            String?
  description       String?
  price             Float
  currency          String             @default("EGP")
  image             String?
  rating            Float              @default(5.0)
  calories          String?
  prepTime          String?
  tags              String             @default("daily")
  isPopular         Boolean            @default(false)
  status            String             @default("ACTIVE")
  stockCount        Int?
  isSoldOut         Boolean            @default(false)
  trackInventory    Boolean            @default(false)
  lowStockThreshold Int?
  merchantId        String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  merchant          User               @relation(fields: [merchantId], references: [id])
  addonGroups       MealAddonGroup[]
  variantGroups     MealVariantGroup[]
  transactions      Transaction[]
}

model MealVariantGroup {
  id        String              @id @default(uuid())
  mealId    String
  name      String
  required  Boolean             @default(true)
  minSelect Int                 @default(1)
  maxSelect Int                 @default(1)
  sortOrder Int                 @default(0)
  meal      Meal                @relation(fields: [mealId], references: [id], onDelete: Cascade)
  options   MealVariantOption[]
}

model MealVariantOption {
  id          String           @id @default(uuid())
  groupId     String
  name        String
  priceDelta  Float            @default(0.0)
  isAvailable Boolean          @default(true)
  sortOrder   Int              @default(0)
  group       MealVariantGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model MealAddonGroup {
  id        String            @id @default(uuid())
  mealId    String
  name      String
  required  Boolean           @default(false)
  minSelect Int               @default(0)
  maxSelect Int               @default(99)
  sortOrder Int               @default(0)
  meal      Meal              @relation(fields: [mealId], references: [id], onDelete: Cascade)
  options   MealAddonOption[]
}

model MealAddonOption {
  id          String         @id @default(uuid())
  groupId     String
  name        String
  priceDelta  Float          @default(0.0)
  isAvailable Boolean        @default(true)
  sortOrder   Int            @default(0)
  group       MealAddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model HubPost {
  id         String   @id @default(uuid())
  content    String
  category   String   @default("general")
  imageUrl   String?
  likesCount Int      @default(0)
  commentsCount Int   @default(0)
  isFlagged  Boolean  @default(false)
  flagReason String?
  status     String   @default("ACTIVE")
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id])
  comments   HubComment[]
  likes      HubLike[]
}

model Referral {
  id            String   @id @default(uuid())
  code          String
  status        String   @default("COMPLETED")
  pointsAwarded Int      @default(50)
  referrerId    String
  referredId    String
  createdAt     DateTime @default(now())
  referred      User     @relation("referred", fields: [referredId], references: [id])
  referrer      User     @relation("referrer", fields: [referrerId], references: [id])
}

model Campaign {
  id          String    @id @default(uuid())
  title       String
  message     String
  targetRole  String?
  targetUni   String?
  status      String    @default("DRAFT")
  sentAt      DateTime?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("GENERAL")
  isRead    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PromoCode {
  id             String        @id @default(uuid())
  code           String        @unique
  discountType   String
  discountAmount Float
  maxUses        Int           @default(0)
  currentUses    Int           @default(0)
  expiresAt      DateTime?
  applicableType String
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orders         Order[]
  transactions   Transaction[]
}

model OTP {
  id         String   @id @default(uuid())
  identifier String
  code       String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ServiceProvider {
  id          String           @id @default(uuid())
  name        String
  phone       String
  category    String
  description String?
  priceRange  String?
  rating      Float            @default(0)
  reviewCount Int              @default(0)
  available   Boolean          @default(true)
  verified    Boolean          @default(false)
  imageUrl    String?
  location    String?          @default("Assiut")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  bookings    ServiceBooking[]
}

model ServiceBooking {
  id           String          @id @default(uuid())
  status       String          @default("PENDING")
  date         String
  timeSlot     String
  notes        String?
  rating       Int?
  review       String?
  userId       String
  providerId   String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  provider     ServiceProvider @relation(fields: [providerId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model CleaningPackage {
  id          String            @id @default(uuid())
  name        String
  description String?
  price       Float
  duration    String?
  frequency   String            @default("ONE_TIME")
  includes    String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  bookings    CleaningBooking[]
}

model CleaningBooking {
  id           String          @id @default(uuid())
  status       String          @default("PENDING")
  date         String
  timeSlot     String
  address      String
  notes        String?
  rating       Int?
  review       String?
  userId       String
  packageId    String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  package      CleaningPackage @relation(fields: [packageId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  module    String
  targetId  String?
  details   String?
  adminId   String?
  createdAt DateTime @default(now())
  admin     User?    @relation("AdminAuditLogs", fields: [adminId], references: [id])
}

model Transaction {
  id                    String               @id @default(uuid())
  txnCode               String               @unique
  type                  String
  status                String               @default("PENDING")
  userId                String
  providerId            String?
  orderId               String?
  housingId             String?
  serviceBookingId      String?
  cleaningBookingId     String?
  dealId                String?
  mealId                String?
  promoCodeId           String?
  amount                Float                @default(0.0)
  currency              String               @default("EGP")
  subtotal              Float                @default(0.0)
  discountTotal         Float                @default(0.0)
  feesTotal             Float                @default(0.0)
  deliveryFee           Float                @default(0.0)
  grandTotal            Float                @default(0.0)
  basePriceSnapshot     Float?
  feeComponentsSnapshot String?
  pricingSnapshot       String?
  zoneSnapshot          String?
  pricingRuleId         String?
  commissionRuleId      String?
  commissionSnapshot    String?
  fxSnapshot            String?
  unizyCommissionAmount Float                @default(0.0)
  providerNetAmount     Float                @default(0.0)
  promoSubsidyAmount    Float                @default(0.0)
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  dispatches            Dispatch[]
  payments              Payment[]
  refunds               Refund[]
  cleaningBooking       CleaningBooking?     @relation(fields: [cleaningBookingId], references: [id])
  deal                  Deal?                @relation(fields: [dealId], references: [id])
  housing               HousingListing?      @relation(fields: [housingId], references: [id])
  meal                  Meal?                @relation(fields: [mealId], references: [id])
  order                 Order?               @relation(fields: [orderId], references: [id])
  promoCode             PromoCode?           @relation(fields: [promoCodeId], references: [id])
  serviceBooking        ServiceBooking?      @relation(fields: [serviceBookingId], references: [id])
  user                  User                 @relation(fields: [userId], references: [id])
  transactionHistory   TransactionHistory[]
  transportTrip        TransportTrip?
  customDelivery       CustomDeliveryRequest? @relation("CustomDeliveryTxn")

  @@index([orderId])
  @@index([userId, status])
}

model TransactionHistory {
  id            String      @id @default(uuid())
  transactionId String
  oldStatus     String?
  newStatus     String
  actorId       String
  reason        String?
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Zone {
  id              String           @id @default(uuid())
  name            String           @unique
  city            String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  commissionRules CommissionRule[]
  driverZones     DriverZone[]
  pricingRules    PricingRule[]
}

model PricingRule {
  id            String   @id @default(uuid())
  module        String
  serviceType   String
  basePrice     Float    @default(0)
  feeComponents String?
  zoneId        String?
  effectiveDate DateTime @default(now())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  zone          Zone?    @relation(fields: [zoneId], references: [id])
}

model CommissionRule {
  id                   String   @id @default(uuid())
  module               String
  providerType         String
  unizySharePercent    Float    @default(0)
  providerSharePercent Float    @default(100)
  promoSubsidyImpact   String?
  zoneId               String?
  effectiveDate        DateTime @default(now())
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  zone                 Zone?    @relation(fields: [zoneId], references: [id])
}

model Payment {
  id              String      @id @default(uuid())
  transactionId   String
  amount          Float       @default(0)
  currency        String      @default("EGP")
  method          String
  status          String      @default("PENDING")
  idempotencyKey  String?     @unique
  gatewayRef      String?
  gatewayProvider String?
  paidAt          DateTime?
  failedReason    String?
  expiresAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Refund {
  id             String       @id @default(uuid())
  transactionId  String?
  orderId        String?
  amount         Float
  amountSnapshot Float?
  currency       String       @default("EGP")
  type           String       @default("FULL")
  reason         String
  status         String       @default("REQUESTED")
  requestedById  String
  approvedById   String?
  processedById  String?
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  approvedBy     User?        @relation("RefundApprovals", fields: [approvedById], references: [id])
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  processedBy    User?        @relation("RefundProcessor", fields: [processedById], references: [id])
  requestedBy    User         @relation("RefundRequests", fields: [requestedById], references: [id])
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Settlement {
  id               String   @id @default(uuid())
  providerId       String
  periodStart      DateTime
  periodEnd        DateTime
  grossAmount      Float    @default(0)
  commissionAmount Float    @default(0)
  netAmount        Float    @default(0)
  currency         String   @default("EGP")
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  payouts          Payout[]
  provider         User     @relation("ProviderSettlements", fields: [providerId], references: [id])
}

model Payout {
  id            String     @id @default(uuid())
  settlementId  String
  amount        Float
  currency      String     @default("EGP")
  method        String
  reference     String?
  status        String     @default("PENDING")
  processedById String?
  paidAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  processedBy   User?      @relation("PayoutProcessor", fields: [processedById], references: [id])
  settlement    Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
}

model Dispatch {
  id            String       @id @default(uuid())
  orderId       String
  transactionId String?
  driverId      String?
  status        String       @default("PENDING")
  assignedById  String?
  delayReason   String?
  isOverride    Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  driver        User?        @relation("DriverDispatches", fields: [driverId], references: [id])
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model SLARule {
  id               String      @id @default(uuid())
  module           String
  metric           String
  thresholdMinutes Int
  breachAction     String
  active           Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  breaches         SLABreach[]
}

model SLABreach {
  id           String    @id @default(uuid())
  ruleId       String
  targetId     String
  status       String    @default("OPEN")
  resolvedAt   DateTime?
  resolvedById String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  rule         SLARule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model DriverZone {
  id        String   @id @default(uuid())
  driverId  String
  zoneId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  zone      Zone     @relation(fields: [zoneId], references: [id])

  @@unique([driverId, zoneId])
}

model SavedHousing {
  id               String         @id @default(uuid())
  userId           String
  housingListingId String
  createdAt        DateTime       @default(now())
  listing          HousingListing @relation(fields: [housingListingId], references: [id])
  user             User           @relation("SavedHousing", fields: [userId], references: [id])

  @@unique([userId, housingListingId])
}

model HousingRequest {
  id               String         @id @default(uuid())
  userId           String
  housingListingId String
  type             String
  status           String         @default("PENDING")
  message          String?
  date             DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  listing          HousingListing @relation(fields: [housingListingId], references: [id])
  user             User           @relation("HousingRequests", fields: [userId], references: [id])

  @@index([userId, status])
}

model Report {
  id           String   @id @default(uuid())
  type         String
  targetId     String
  reason       String
  details      String?
  status       String   @default("PENDING")
  actionTaken  String?
  reporterId   String
  targetUserId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reporter     User     @relation("Reporter", fields: [reporterId], references: [id])
  targetUser   User?    @relation("TargetUser", fields: [targetUserId], references: [id])
}

model RewardAccount {
  id             String   @id @default(uuid())
  userId         String   @unique
  currentBalance Float    @default(0.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RewardTransaction {
  id            String    @id @default(uuid())
  type          String
  points        Float
  description   String?
  userId        String
  transactionId String?
  orderId       String?
  adminId       String?
  expiresAt     DateTime?
  expired       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  order         Order?    @relation(fields: [orderId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id                 String              @id @default(uuid())
  userId             String              @unique
  balance            Float               @default(0.0)
  currency           String              @default("EGP")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  walletTransactions WalletTransaction[]
}

model WalletTransaction {
  id            String   @id @default(uuid())
  type          String
  amount        Float
  description   String?
  walletId      String
  transactionId String?
  createdAt     DateTime @default(now())
  wallet        Wallet   @relation(fields: [walletId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  event     String
  userId    String
  module    String?
  metadata  String?
  sessionId String?
  createdAt DateTime @default(now())
}

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

enum UserRole {
  STUDENT
  MERCHANT
  DRIVER
  COURIER
  PROVIDER
  ADMIN_SUPER
  ADMIN_HOUSING
  ADMIN_TRANSPORT
  ADMIN_DELIVERY
  ADMIN_COMMERCE
  ADMIN_SERVICES
}

model CustomDeliveryRequest {
  id              String         @id @default(uuid())
  itemDescription String
  pickupLocation  String?
  dropoffLocation String
  pickupLat       Float?
  pickupLng       Float?
  dropoffLat      Float?
  dropoffLng      Float?
  estimatedCost   Float?
  actualCost      Float?
  deliveryOTP     String?
  failedOtpAttempts Int          @default(0)
  status          OrderStatus @default(PENDING)
  userId          String
  courierId       String?
  transactionId   String?     @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("UserCustomDeliveries", fields: [userId], references: [id])
  courier         User?    @relation("CourierCustomDeliveries", fields: [courierId], references: [id])
  transaction     Transaction? @relation("CustomDeliveryTxn", fields: [transactionId], references: [id])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum HousingStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TripStatus {
  REQUESTED
  ACCEPTED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TransportTrip {
  id              String     @id @default(uuid())
  userId          String
  driverId        String?
  status          TripStatus @default(REQUESTED)
  pickupLocation  String
  pickupLat       Float?
  pickupLng       Float?
  dropoffLocation String
  dropoffLat      Float?
  dropoffLng      Float?
  vehicleType     String
  estimatedPrice  Float
  finalPrice      Float?
  tripOTP         String?
  failedOtpAttempts Int       @default(0)
  transactionId   String?    @unique
  scheduledTime   DateTime?
  cancelReason    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user        User         @relation("TripUser", fields: [userId], references: [id])
  driver      User?        @relation("TripDriver", fields: [driverId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@index([userId, status])
  @@index([driverId, status])
}

model ShuttleBus {
  id           String   @id @default(uuid())
  busNumber    String   @unique
  plateNumber  String   @unique
  lat          Float
  lng          Float
  status       String   @default("ACTIVE") // ACTIVE, IN_REPAIR, OFFLINE
  lastUpdated  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ShuttleStation {
  id        String   @id @default(uuid())
  name      String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampusNotice {
  id          String   @id @default(uuid())
  title       String
  message     String
  type        String   @default("GENERAL") // GENERAL, EVENT, ACADEMIC, EMERGENCY
  university  String   @default("Assiut University")
  expiresAt   DateTime?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoommateRequest {
  id           String   @id @default(uuid())
  userId       String
  budget       Float
  area         String
  gender       String
  moveInDate   DateTime
  notes        String?
  smoking      String
  sleep        String
  cleanliness  String
  study        String
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HubComment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      HubPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model HubLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      HubPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}
